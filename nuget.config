<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Projet perso : on ignore les sources NuGet globales de la machine
       (serveur d'entreprise injoignable hors VPN) et on n'utilise que nuget.org. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
