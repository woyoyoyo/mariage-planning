@page "/parametres"
@inject SettingsService Config
@inject WeddingStore Store
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Mariage Planning — Paramètres</PageTitle>

<header class="page-header">
    <h1>⚙️ Paramètres</h1>
</header>

<div class="settings-form">
    <label class="form-field">
        <span class="form-label">ID du Gist</span>
        <input class="form-input" type="text" @bind="_gistId"
               placeholder="ex : bd451c30da0d..." autocapitalize="off" autocorrect="off" spellcheck="false" />
        <span class="form-hint">La chaîne dans l'URL du Gist (gist.github.com/toncompte/<b>ID</b>). Suffit pour lire le planning.</span>
    </label>

    <label class="form-field">
        <span class="form-label">Token GitHub (PAT)</span>
        <input class="form-input" type="@(_showToken ? "text" : "password")" @bind="_token"
               placeholder="ghp_..." autocapitalize="off" autocorrect="off" spellcheck="false" />
        <span class="form-hint">Nécessaire uniquement pour modifier le planning. Stocké sur ce téléphone, nulle part ailleurs.</span>
    </label>

    <label class="show-token">
        <input type="checkbox" @bind="_showToken" /> Afficher le token
    </label>

    <button class="action-btn btn-refresh" @onclick="SaveAsync" disabled="@_busy">
        @(_busy ? "⏳ Vérification…" : "💾 Enregistrer et tester")
    </button>

    @if (_feedback is not null)
    {
        <div class="sync-status @_feedbackClass">@_feedback</div>
    }

    @if (Store.Data?.People.Count > 0)
    {
        <div class="form-field">
            <span class="form-label">Qui es-tu ? (onglet Moi)</span>
            <select class="form-input" value="@(Config.CurrentPerson ?? "")" @onchange="OnPersonChangedAsync">
                <option value="">— Non défini —</option>
                @foreach (var person in Store.Data.People)
                {
                    <option value="@person.Id">@person.Name</option>
                }
            </select>
        </div>
    }

    @if (Config.CanSave && Store.Data is not null)
    {
        <div class="share-config">
            <h2 class="share-config-title">👥 Personnes</h2>

            <div class="people-list">
                @foreach (var person in Store.Data.People)
                {
                    var pid = person.Id;
                    <div class="people-row">
                        <span class="person-badge" style="--person-color: @person.Color">@person.Name</span>
                        <button class="btn-card-icon people-delete"
                                @onclick="() => DeletePersonAsync(pid)"
                                disabled="@_personBusy"
                                title="Supprimer @person.Name">🗑️</button>
                    </div>
                }
            </div>

            @if (_addingPerson)
            {
                <div class="add-form">
                    <div class="add-form-row">
                        <label class="form-field form-grow">
                            <span class="form-label">Prénom *</span>
                            <input class="form-input" type="text" @bind="_newPersonName"
                                   placeholder="ex : Marie"
                                   autocapitalize="words" autocorrect="off" />
                        </label>
                        <label class="form-field">
                            <span class="form-label">Couleur</span>
                            <input type="color" class="color-picker" @bind="_newPersonColor" />
                        </label>
                    </div>
                    <div class="add-form-actions">
                        <button class="action-btn btn-clear" @onclick="() => _addingPerson = false">Annuler</button>
                        <button class="action-btn btn-refresh" @onclick="AddPersonAsync"
                                disabled="@(_personBusy || string.IsNullOrWhiteSpace(_newPersonName))">
                            @(_personBusy ? "⏳…" : "➕ Ajouter")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <button class="action-btn btn-add" @onclick="() => _addingPerson = true">
                    ➕ Ajouter une personne
                </button>
            }

            @if (_personError is not null)
            {
                <div class="sync-status sync-warn">⚠️ @_personError</div>
            }
        </div>
    }

    @if (!Config.CanSave && Config.LockedToken is not null)
    {
        <div class="share-config">
            <h2 class="share-config-title">🔓 Déverrouiller la modification</h2>
            <p class="form-hint">
                Tu as reçu ce planning en lecture. Si tu fais partie des organisateurs,
                entre le mot de passe du groupe pour pouvoir le modifier.
            </p>

            <label class="form-field">
                <span class="form-label">Mot de passe du groupe</span>
                <input class="form-input" type="password" @bind="_unlockPassword" @bind:event="oninput"
                       autocapitalize="off" autocorrect="off" spellcheck="false" />
            </label>

            <button class="action-btn btn-refresh" @onclick="UnlockAsync"
                    disabled="@(_unlockBusy || string.IsNullOrWhiteSpace(_unlockPassword))">
                @(_unlockBusy ? "⏳ Déchiffrement…" : "🔓 Déverrouiller")
            </button>

            @if (_unlockError is not null)
            {
                <div class="sync-status sync-warn">⚠️ @_unlockError</div>
            }
        </div>
    }

    @if (Config.CanSave)
    {
        <div class="share-config">
            <h2 class="share-config-title">📲 Partager la configuration</h2>
            <p class="form-hint">
                Génère un lien (et son QR code) à partager. Celui qui le scanne voit le planning
                en <b>lecture</b> ; ceux qui ont le mot de passe peuvent déverrouiller la <b>modification</b>
                (le token est chiffré avec ce mot de passe dans le lien).
            </p>

            <label class="form-field">
                <span class="form-label">Mot de passe du groupe</span>
                <input class="form-input" type="text" @bind="_sharePassword" @bind:event="oninput"
                       placeholder="ex : le nom du chat de Bénédicte" autocapitalize="off" autocorrect="off" spellcheck="false" />
            </label>

            <button class="action-btn btn-refresh" @onclick="GenerateShareAsync"
                    disabled="@(_shareBusy || string.IsNullOrWhiteSpace(_sharePassword))">
                @(_shareBusy ? "⏳ Chiffrement…" : "🔗 Générer le lien à partager")
            </button>

            @if (_shareUrl is not null)
            {
                <div id="share-qr" class="share-qr"></div>
                <div class="share-url">@_shareUrl</div>
                <div class="add-form-actions">
                    <button class="action-btn btn-clear" @onclick="CopyShareUrlAsync">📋 Copier</button>
                    <button class="action-btn btn-refresh" @onclick="ShareUrlAsync">📤 Partager</button>
                </div>
                @if (_shareCopied)
                {
                    <div class="sync-status sync-ok">✅ Lien copié.</div>
                }
            }
        </div>
    }

    <button class="action-btn btn-clear" @onclick="ClearAsync" disabled="@_busy">
        🗑️ Effacer la configuration
    </button>

    <p class="app-version">Mariage Planning — v@(AppInfo.Version)</p>
</div>

@code {
    private string? _gistId;
    private string? _token;
    private bool _showToken;
    private bool _busy;
    private string? _feedback;
    private string _feedbackClass = "";

    protected override async Task OnInitializedAsync()
    {
        await Config.EnsureLoadedAsync();
        await Store.EnsureLoadedAsync();
        _gistId = Config.GistId;
        _token = Config.Token;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _feedback = null;

        await Config.SaveAsync(_gistId, _token);
        await Store.ReloadAsync();

        if (Store.Source == DataSource.Gist)
        {
            var days = Store.Data?.Days.Count ?? 0;
            _feedback = $"✅ Connecté au Gist — {days} jour(s) chargé(s).";
            _feedbackClass = "sync-ok";
        }
        else if (!Config.IsConfigured)
        {
            _feedback = "ℹ️ Aucun Gist configuré — l'app affiche la démo.";
            _feedbackClass = "sync-demo";
        }
        else
        {
            _feedback = $"⚠️ Connexion impossible : {Store.LoadError ?? "vérifie l'ID du Gist et le réseau"}";
            _feedbackClass = "sync-warn";
        }

        _busy = false;
    }

    private async Task OnPersonChangedAsync(ChangeEventArgs e) =>
        await Config.SetCurrentPersonAsync(e.Value?.ToString());

    // --- Gestion des personnes ---

    private bool _addingPerson;
    private string? _newPersonName;
    private string _newPersonColor = "#6366f1";
    private bool _personBusy;
    private string? _personError;

    private async Task AddPersonAsync()
    {
        _personBusy = true;
        _personError = null;
        var name = _newPersonName!.Trim();
        var color = _newPersonColor;
        var id = Guid.NewGuid().ToString("N")[..8];

        var (ok, error) = await Store.SaveAsync(data =>
        {
            data.People.Add(new Person { Id = id, Name = name, Color = color });
            return true;
        });

        _personBusy = false;
        if (ok)
        {
            _newPersonName = null;
            _newPersonColor = "#6366f1";
            _addingPerson = false;
        }
        else
        {
            _personError = error;
        }
    }

    private async Task DeletePersonAsync(string personId)
    {
        _personBusy = true;
        _personError = null;

        var (ok, error) = await Store.SaveAsync(data =>
        {
            data.People.RemoveAll(p => p.Id == personId);
            foreach (var day in data.Days)
                foreach (var task in day.Activities)
                    task.AssignedTo.Remove(personId);
            return true;
        });

        if (ok && Config.CurrentPerson == personId)
            await Config.SetCurrentPersonAsync(null);

        _personBusy = false;
        if (!ok)
            _personError = error;
    }

    // --- Partage de la configuration (URL chiffrée + QR code) ---

    private string? _sharePassword;
    private string? _shareUrl;
    private bool _shareBusy;
    private bool _shareCopied;

    private async Task GenerateShareAsync()
    {
        _shareBusy = true;
        _shareCopied = false;

        // Format : #<gistId>.<token chiffré> — l'ID en clair donne la lecture,
        // le mot de passe déverrouille le token (donc la modification).
        // Le tout voyage dans le fragment (#...) : il n'atteint jamais le serveur.
        var blob = await JS.InvokeAsync<string>("mariage.encryptConfig", _sharePassword, Config.Token);
        _shareUrl = $"{Nav.BaseUri}rejoindre#{Config.GistId}.{blob}";
        _shareBusy = false;

        StateHasChanged();
        await Task.Yield(); // laisse Blazor rendre le conteneur #share-qr avant d'y dessiner
        await JS.InvokeVoidAsync("mariage.makeQr", "share-qr", _shareUrl);
    }

    private async Task CopyShareUrlAsync()
    {
        await JS.InvokeVoidAsync("mariage.copyText", _shareUrl);
        _shareCopied = true;
    }

    private async Task ShareUrlAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("mariage.shareText", _shareUrl);
        }
        catch { /* share non supporté ou annulé */ }
    }

    // --- Déverrouillage de la modification (token chiffré reçu via un lien) ---

    private string? _unlockPassword;
    private bool _unlockBusy;
    private string? _unlockError;

    private async Task UnlockAsync()
    {
        _unlockBusy = true;
        _unlockError = null;

        try
        {
            var token = await JS.InvokeAsync<string>("mariage.decryptConfig", _unlockPassword, Config.LockedToken);
            await Config.SaveAsync(Config.GistId, token);
            _token = token;
            _feedback = "✏️ Modification déverrouillée sur ce téléphone.";
            _feedbackClass = "sync-ok";
        }
        catch (JSException)
        {
            _unlockError = "Mot de passe incorrect — réessaie.";
        }
        catch (Exception ex)
        {
            _unlockError = ex.Message;
        }
        finally
        {
            _unlockBusy = false;
        }
    }

    private async Task ClearAsync()
    {
        _gistId = null;
        _token = null;
        await Config.SaveAsync(null, null);
        await Config.SetCurrentPersonAsync(null);
        await Config.SetLockedTokenAsync(null);
        await Store.ReloadAsync();
        _feedback = "🗑️ Configuration effacée — retour aux données de démo.";
        _feedbackClass = "sync-demo";
    }
}
