@page "/parametres"
@inject SettingsService Config
@inject WeddingStore Store
@inject GeminiService Gemini
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Mariage Planning — Paramètres</PageTitle>

<header class="page-header">
    <h1>⚙️ Paramètres</h1>
</header>

<div class="settings-form">

    @* ── Statut de connexion ──────────────────────────────────────────────── *@
    @if (Config.CanSave)
    {
        <div class="sync-status sync-ok">✅ Connecté — modification active sur ce téléphone.</div>
    }
    else if (Config.IsConfigured)
    {
        @if (Config.LockedToken is not null)
        {
            <div class="sync-status sync-readonly">👁️ Lecture seule — entre le mot de passe ci-dessous pour modifier.</div>
        }
        else
        {
            <div class="sync-status sync-readonly">👁️ Lecture seule — scanne le QR code complet pour obtenir le mot de passe.</div>
        }
    }
    else
    {
        <div class="sync-status sync-demo">💡 Scanne le QR code des organisateurs, ou configure l'accès ci-dessous.</div>
    }

    @if (_feedback is not null)
    {
        <div class="sync-status @_feedbackClass">@_feedback</div>
    }

    @* ── Déverrouillage ───────────────────────────────────────────────────── *@
    @if (!Config.CanSave && Config.LockedToken is not null)
    {
        <div class="share-config">
            <h2 class="share-config-title">🔓 Déverrouiller la modification</h2>
            <label class="form-field">
                <span class="form-label">Mot de passe du groupe</span>
                <input class="form-input" type="password" @bind="_unlockPassword" @bind:event="oninput"
                       placeholder="Mot de passe reçu avec le QR code"
                       autocapitalize="off" autocorrect="off" spellcheck="false" />
            </label>
            <button class="action-btn btn-refresh" @onclick="UnlockAsync"
                    disabled="@(_unlockBusy || string.IsNullOrWhiteSpace(_unlockPassword))">
                @(_unlockBusy ? "⏳ Déchiffrement…" : "🔓 Déverrouiller")
            </button>
            @if (_unlockError is not null) { <div class="sync-status sync-warn">⚠️ @_unlockError</div> }
        </div>
    }

    @* ── Qui suis-je ? ────────────────────────────────────────────────────── *@
    @if (Store.Data?.People.Count > 0)
    {
        <div class="form-field">
            <span class="form-label">Qui es-tu ?</span>
            <select class="form-input" value="@(Config.CurrentPerson ?? "")" @onchange="OnPersonChangedAsync">
                <option value="">— Non défini —</option>
                @foreach (var person in Store.Data.People)
                {
                    <option value="@person.Id">@person.Name</option>
                }
            </select>
        </div>
    }

    @* ── Raccourcis vers les autres pages ─────────────────────────────────── *@
    <div class="settings-shortcuts">
        <a class="settings-shortcut" href="partager">
            <span class="settings-shortcut-icon">📲</span>
            <span class="settings-shortcut-label">Partager le planning</span>
            <span class="settings-shortcut-arrow">›</span>
        </a>
        @if (Store.CanEdit)
        {
            <a class="settings-shortcut" href="personnes">
                <span class="settings-shortcut-icon">👥</span>
                <span class="settings-shortcut-label">Personnes & Équipes</span>
                <span class="settings-shortcut-arrow">›</span>
            </a>
        }
    </div>

    @* ── Assistant IA ─────────────────────────────────────────────────────── *@
    <details class="config-section" open="@(!Gemini.IsConfigured)">
        <summary class="config-section-summary">🤖 Assistant IA (Gemini)</summary>
        <div class="config-section-body">
            <p class="form-hint">
                Clé API Google Gemini (gratuite sur <b>aistudio.google.com</b>).
                Stockée uniquement sur ce téléphone.
            </p>
            <label class="form-field">
                <span class="form-label">Clé Gemini</span>
                <input class="form-input" type="@(_showGeminiKey ? "text" : "password")"
                       @bind="_geminiKey"
                       placeholder="AIza..."
                       autocapitalize="off" autocorrect="off" spellcheck="false" />
            </label>
            <label class="show-token">
                <input type="checkbox" @bind="_showGeminiKey" /> Afficher la clé
            </label>
            <label class="form-field">
                <span class="form-label">Modèle</span>
                <select class="form-input" @bind="_geminiModel">
                    <option value="gemini-2.5-flash-lite">gemini-2.5-flash-lite — rapide, économique (recommandé)</option>
                    <option value="gemini-2.5-flash">gemini-2.5-flash — meilleur rapport qualité/prix</option>
                    <option value="gemini-3.1-flash-lite">gemini-3.1-flash-lite — haute perf, coût réduit</option>
                    <option value="gemini-3.5-flash">gemini-3.5-flash — plus intelligent (peut être saturé)</option>
                </select>
            </label>
            <div class="add-form-actions">
                <button class="action-btn btn-refresh" @onclick="SaveGeminiKeyAsync" disabled="@_geminiKeySaving">
                    @(_geminiKeySaving ? "⏳…" : "💾 Enregistrer")
                </button>
                <button class="action-btn btn-clear" @onclick="TestGeminiKeyAsync"
                        disabled="@(_geminiKeySaving || _geminiKeyTesting || !Gemini.IsConfigured)">
                    @(_geminiKeyTesting ? "⏳ Test…" : "🧪 Tester")
                </button>
            </div>
            @if (_geminiKeyFeedback is not null)
            {
                <div class="sync-status @(_geminiKeyOk ? "sync-ok" : "sync-warn")">@_geminiKeyFeedback</div>
            }
        </div>
    </details>

    @* ── Configuration de l'accès au Gist ────────────────────────────────── *@
    <details class="config-section" open="@(!Config.IsConfigured)">
        <summary class="config-section-summary">🔧 Configuration de l'accès</summary>
        <div class="config-section-body">
            <label class="form-field">
                <span class="form-label">ID du Gist</span>
                <input class="form-input" type="text" @bind="_gistId"
                       placeholder="ex : bd451c30da0d..." autocapitalize="off" autocorrect="off" spellcheck="false" />
                <span class="form-hint">La chaîne dans l'URL du Gist. Suffit pour lire.</span>
            </label>
            <label class="form-field">
                <span class="form-label">Token GitHub (PAT)</span>
                <input class="form-input" type="@(_showToken ? "text" : "password")" @bind="_token"
                       placeholder="ghp_..." autocapitalize="off" autocorrect="off" spellcheck="false" />
                <span class="form-hint">Nécessaire pour modifier le planning.</span>
            </label>
            <label class="show-token">
                <input type="checkbox" @bind="_showToken" /> Afficher le token
            </label>
            <button class="action-btn btn-refresh" @onclick="SaveAsync" disabled="@_busy">
                @(_busy ? "⏳ Vérification…" : "💾 Enregistrer et tester")
            </button>
        </div>
    </details>

    @* ── Actions ─────────────────────────────────────────────────────────── *@
    <button class="action-btn btn-hard-refresh" @onclick="HardRefreshAsync" disabled="@_busy">
        🔄 Forcer la mise à jour de l'app
    </button>

    <div class="actions-footer">
        @if (Config.CanSave)
        {
            <button class="action-btn btn-disconnect" @onclick="DisconnectAsync" disabled="@_busy">
                🔒 Se déconnecter
            </button>
        }
        <button class="action-btn btn-clear" @onclick="ClearAsync" disabled="@_busy">
            🗑️ Effacer tout
        </button>
    </div>

    <p class="app-version">Mariage Planning — v@(AppInfo.Version)</p>
</div>

@code {
    private string? _gistId;
    private string? _token;
    private bool    _showToken;
    private bool    _busy;
    private string? _feedback;
    private string  _feedbackClass = "";

    private string? _geminiKey;
    private string  _geminiModel  = "";
    private bool    _showGeminiKey;
    private bool    _geminiKeySaving;
    private bool    _geminiKeyTesting;
    private string? _geminiKeyFeedback;
    private bool    _geminiKeyOk;

    private string? _unlockPassword;
    private bool    _unlockBusy;
    private string? _unlockError;

    protected override async Task OnInitializedAsync()
    {
        await Config.EnsureLoadedAsync();
        await Store.EnsureLoadedAsync();
        _gistId      = Config.GistId;
        _token       = Config.Token;
        _geminiKey   = Config.GeminiApiKey;
        _geminiModel = Config.GeminiModel;
    }

    private async Task OnPersonChangedAsync(ChangeEventArgs e) =>
        await Config.SetCurrentPersonAsync(e.Value?.ToString());

    private async Task SaveGeminiKeyAsync()
    {
        _geminiKeySaving = true; _geminiKeyFeedback = null;
        await Config.SetGeminiApiKeyAsync(_geminiKey);
        if (!string.IsNullOrWhiteSpace(_geminiModel))
            await Config.SetGeminiModelAsync(_geminiModel);
        _geminiKeySaving = false;
        _geminiKeyOk = Gemini.IsConfigured;
        _geminiKeyFeedback = Gemini.IsConfigured
            ? "✅ Clé enregistrée — clique 🧪 Tester pour vérifier."
            : "🗑️ Clé supprimée.";
    }

    private async Task TestGeminiKeyAsync()
    {
        _geminiKeyTesting = true; _geminiKeyFeedback = null;
        try
        {
            await Gemini.ChatAsync("Réponds uniquement avec le mot : OK", [], "Test de connexion.");
            _geminiKeyOk = true;
            _geminiKeyFeedback = $"✅ Connexion OK — modèle : {Config.GeminiModel}";
        }
        catch (Exception ex)
        {
            _geminiKeyOk = false;
            _geminiKeyFeedback = $"⚠️ {ex.Message}";
        }
        finally { _geminiKeyTesting = false; }
    }

    private async Task SaveAsync()
    {
        _busy = true; _feedback = null;
        await Config.SaveAsync(_gistId, _token);
        await Store.ReloadAsync();
        if (Store.Source == DataSource.Gist)
        {
            _feedback = $"✅ Connecté — {Store.Data?.Days.Count ?? 0} jour(s) chargé(s).";
            _feedbackClass = "sync-ok";
        }
        else if (!Config.IsConfigured)
        {
            _feedback = "ℹ️ Aucun Gist configuré — démo.";
            _feedbackClass = "sync-demo";
        }
        else
        {
            _feedback = $"⚠️ Connexion impossible : {Store.LoadError ?? "vérifie l'ID du Gist et le réseau"}";
            _feedbackClass = "sync-warn";
        }
        _busy = false;
    }

    private async Task UnlockAsync()
    {
        _unlockBusy = true; _unlockError = null;
        try
        {
            var token = await JS.InvokeAsync<string>("mariage.decryptConfig", _unlockPassword, Config.LockedToken);
            await Config.SaveAsync(Config.GistId, token);
            _token = token;
            _feedback = "✏️ Modification déverrouillée.";
            _feedbackClass = "sync-ok";
        }
        catch (JSException) { _unlockError = "Mot de passe incorrect — réessaie."; }
        catch (Exception ex) { _unlockError = ex.Message; }
        finally { _unlockBusy = false; }
    }

    private async Task DisconnectAsync()
    {
        _token = null;
        await Config.SaveAsync(Config.GistId, null);
        await Store.ReloadAsync();
        _feedback = "🔒 Déconnecté.";
        _feedbackClass = "sync-readonly";
    }

    private async Task HardRefreshAsync()
    {
        _busy = true;
        await JS.InvokeVoidAsync("mariage.hardRefresh");
    }

    private async Task ClearAsync()
    {
        _gistId = null; _token = null;
        await Config.SaveAsync(null, null);
        await Config.SetCurrentPersonAsync(null);
        await Config.SetLockedTokenAsync(null);
        await Store.ReloadAsync();
        _feedback = "🗑️ Configuration effacée — retour aux données de démo.";
        _feedbackClass = "sync-demo";
    }
}
