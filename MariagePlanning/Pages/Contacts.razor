@page "/contacts"
@implements IDisposable
@inject WeddingStore Store
@inject SettingsService Config

<PageTitle>Mariage Planning — Contacts</PageTitle>

<header class="page-header no-print">
    <h1>📇 Contacts</h1>
</header>

@* ── Barre d'onglets ────────────────────────────────────────────────────── *@
@if (Store.Data is not null)
{
    <div class="tab-bar no-print">
        <button class="tab @(_tab == Tab.Contacts ? "tab-active" : "")" @onclick='() => _tab = Tab.Contacts'>
            📇 Prestataires
            <span class="tab-count">@Store.Data.Contacts.Count</span>
        </button>
        <button class="tab @(_tab == Tab.Personnes ? "tab-active" : "")" @onclick='() => _tab = Tab.Personnes'>
            👤 Personnes
            <span class="tab-count">@Store.Data.People.Count</span>
        </button>
        <button class="tab @(_tab == Tab.Equipes ? "tab-active" : "")" @onclick='() => _tab = Tab.Equipes'>
            👥 Équipes
            <span class="tab-count">@Store.Data.Teams.Count</span>
        </button>
        <button class="tab @(_tab == Tab.Lieux ? "tab-active" : "")" @onclick='() => _tab = Tab.Lieux'>
            📍 Lieux
            <span class="tab-count">@Store.Data.Venues.Count</span>
        </button>
    </div>
}

@if (Store.Data is null)
{
    <div class="loading-message">Chargement…</div>
}
else
{
    <div class="no-print">

    @* ── Onglet Prestataires ────────────────────────────────────────────── *@
    @if (_tab == Tab.Contacts)
    {
        @foreach (var contact in Store.Data.Contacts)
        {
            var cid = contact.Id;
            @if (_editingId == cid)
            {
                <div class="add-form edit-form contact-form">
                    @ContactFields()
                    @if (_error is not null)
                    {
                        <div class="sync-status sync-warn">⚠️ @_error</div>
                    }
                    <div class="add-form-actions">
                        <button class="action-btn btn-clear" @onclick="CancelForm" disabled="@_busy">Annuler</button>
                        <button class="action-btn btn-refresh" @onclick="SaveEditAsync"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(_fName))">
                            @(_busy ? "⏳…" : "💾 Enregistrer")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="contact-card">
                    <div class="contact-card-head">
                        <span class="contact-name">@contact.Name</span>
                        @if (Store.CanEdit)
                        {
                            <div class="people-row-actions">
                                <button class="btn-card-icon" @onclick="() => StartEdit(contact)" title="Modifier">✏️</button>
                                <button class="btn-card-icon people-delete" @onclick="() => DeleteAsync(cid)" title="Supprimer">🗑️</button>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(contact.ContactPerson))
                    {
                        <div class="contact-detail">👤 @contact.ContactPerson</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(contact.Phone))
                    {
                        <a href="tel:@contact.Phone" class="contact-action">📞 @contact.Phone</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(contact.Address))
                    {
                        <a href="@MapsUrl(contact.Address)" target="_blank" rel="noopener" class="contact-action">
                            📍 @contact.Address
                        </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(contact.Notes))
                    {
                        <p class="contact-notes">💡 @contact.Notes</p>
                    }
                    @foreach (var lnk in contact.Links.Where(l => !string.IsNullOrWhiteSpace(l)))
                    {
                        <a href="@lnk" target="_blank" rel="noopener" class="contact-action contact-link-url">
                            🔗 @DisplayLink(lnk)
                        </a>
                    }
                </div>
            }
        }

        @if (Store.Data.Contacts.Count == 0 && !Store.CanEdit)
        {
            <div class="empty-message">Aucun prestataire pour l'instant.</div>
        }

        @if (Store.CanEdit)
        {
            @if (_addingNew)
            {
                <div class="add-form contact-form">
                    @ContactFields()
                    @if (_error is not null)
                    {
                        <div class="sync-status sync-warn">⚠️ @_error</div>
                    }
                    <div class="add-form-actions">
                        <button class="action-btn btn-clear" @onclick="CancelForm" disabled="@_busy">Annuler</button>
                        <button class="action-btn btn-refresh" @onclick="SaveAddAsync"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(_fName))">
                            @(_busy ? "⏳…" : "➕ Ajouter")
                        </button>
                    </div>
                </div>
            }
            else if (_editingId is null)
            {
                <button class="action-btn btn-add contact-add-btn" @onclick="StartAdd">
                    ➕ Ajouter un prestataire
                </button>
            }
        }
    }

    @* ── Onglet Personnes ──────────────────────────────────────────────── *@
    else if (_tab == Tab.Personnes)
    {
        @if (Store.Data.People.Count == 0)
        {
            <div class="empty-message">Aucune personne configurée.</div>
        }
        else
        {
            <div class="person-export-list">
                @foreach (var person in Store.Data.People)
                {
                    var pid = person.Id;
                    var taskCount = Store.OrderedDays.Sum(d =>
                        d.Activities.Count(t => WeddingStore.ConcernsPerson(t, pid)));
                    <div class="person-export-card">
                        <div class="person-export-avatar" style="background:@person.Color">
                            @person.Name[0]
                        </div>
                        <div class="person-export-info">
                            <div class="person-export-name">@person.Name</div>
                            <div class="person-export-meta">
                                @taskCount tâche@(taskCount > 1 ? "s" : "")
                                @if (!string.IsNullOrWhiteSpace(person.Phone))
                                {
                                    <span> · </span>
                                    <a href="tel:@person.Phone" class="person-export-phone">@person.Phone</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }

    @* ── Onglet Équipes ────────────────────────────────────────────────── *@
    else if (_tab == Tab.Equipes)
    {
        @if (Store.Data.Teams.Count == 0)
        {
            <div class="empty-message">Aucune équipe configurée.</div>
        }
        else
        {
            @foreach (var team in Store.Data.Teams)
            {
                var members = team.MemberIds
                    .Select(mid => Store.PersonById(mid)?.Name)
                    .Where(n => n is not null)
                    .ToList();
                <div class="contact-card">
                    <div class="contact-card-head">
                        <span class="person-badge" style="--person-color:@team.Color">@team.Name</span>
                    </div>
                    <div class="contact-detail">
                        👥 @(members.Count == 0 ? "Aucun membre" : string.Join(", ", members))
                    </div>
                </div>
            }
        }
    }

    @* ── Onglet Lieux ──────────────────────────────────────────────────── *@
    else if (_tab == Tab.Lieux)
    {
        @foreach (var venue in Store.Data.Venues)
        {
            var vid = venue.Id;
            @if (_vEditingId == vid)
            {
                <div class="add-form edit-form contact-form">
                    @VenueFields()
                    @if (_vError is not null)
                    {
                        <div class="sync-status sync-warn">⚠️ @_vError</div>
                    }
                    <div class="add-form-actions">
                        <button class="action-btn btn-clear" @onclick="CancelVenueForm" disabled="@_vBusy">Annuler</button>
                        <button class="action-btn btn-refresh" @onclick="SaveVenueEditAsync"
                                disabled="@(_vBusy || string.IsNullOrWhiteSpace(_vfName))">
                            @(_vBusy ? "⏳…" : "💾 Enregistrer")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="contact-card">
                    <div class="contact-card-head">
                        <span class="contact-name">@venue.Name</span>
                        @if (Store.CanEdit)
                        {
                            <div class="people-row-actions">
                                <button class="btn-card-icon" @onclick="() => StartVenueEdit(venue)" title="Modifier">✏️</button>
                                <button class="btn-card-icon people-delete" @onclick="() => DeleteVenueAsync(vid)" title="Supprimer">🗑️</button>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(venue.Address))
                    {
                        <a href="@MapsUrl(venue.Address)" target="_blank" rel="noopener" class="contact-action">
                            📍 @venue.Address
                        </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(venue.Notes))
                    {
                        <p class="contact-notes">💡 @venue.Notes</p>
                    }
                    @foreach (var cid in venue.ContactIds)
                    {
                        var lc = Store.Data!.Contacts.FirstOrDefault(c => c.Id == cid);
                        if (lc is null) continue;
                        <div class="contact-detail venue-linked-row">
                            <span>📇 @lc.Name</span>
                            @if (!string.IsNullOrWhiteSpace(lc.Phone))
                            {
                                <a href="tel:@lc.Phone" class="venue-linked-phone">📞 @lc.Phone</a>
                            }
                        </div>
                    }
                    @foreach (var pid in venue.PersonIds)
                    {
                        var lp = Store.PersonById(pid);
                        if (lp is null) continue;
                        <div class="contact-detail venue-linked-row">
                            <span class="person-badge" style="--person-color:@lp.Color">@lp.Name</span>
                            @if (!string.IsNullOrWhiteSpace(lp.Phone))
                            {
                                <a href="tel:@lp.Phone" class="venue-linked-phone">📞 @lp.Phone</a>
                            }
                        </div>
                    }
                </div>
            }
        }

        @if (Store.Data.Venues.Count == 0 && !Store.CanEdit)
        {
            <div class="empty-message">Aucun lieu enregistré.</div>
        }

        @if (Store.CanEdit)
        {
            @if (_vAddingNew)
            {
                <div class="add-form contact-form">
                    @VenueFields()
                    @if (_vError is not null)
                    {
                        <div class="sync-status sync-warn">⚠️ @_vError</div>
                    }
                    <div class="add-form-actions">
                        <button class="action-btn btn-clear" @onclick="CancelVenueForm" disabled="@_vBusy">Annuler</button>
                        <button class="action-btn btn-refresh" @onclick="SaveVenueAddAsync"
                                disabled="@(_vBusy || string.IsNullOrWhiteSpace(_vfName))">
                            @(_vBusy ? "⏳…" : "➕ Ajouter")
                        </button>
                    </div>
                </div>
            }
            else if (_vEditingId is null)
            {
                <button class="action-btn btn-add contact-add-btn" @onclick="StartVenueAdd">
                    ➕ Ajouter un lieu
                </button>
            }
        }
    }

    </div>

}

@code {
    private enum Tab { Contacts, Personnes, Equipes, Lieux }
    private Tab _tab = Tab.Contacts;

    // ── Contacts ─────────────────────────────────────────────────────────────

    private bool _addingNew;
    private string? _editingId;
    private bool _busy;
    private string? _error;

    private string? _fName;
    private string? _fPerson;
    private string? _fPhone;
    private string? _fAddress;
    private string? _fNotes;
    private List<string> _fLinks = [];
    private string? _newLinkInput;

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnChanged;
        await Store.EnsureLoadedAsync();
    }

    public void Dispose() => Store.Changed -= OnChanged;

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private void StartAdd()
    {
        _addingNew = true;
        _editingId = null;
        _fName = null; _fPerson = null; _fPhone = null; _fAddress = null; _fNotes = null;
        _fLinks = []; _newLinkInput = null; _error = null;
    }

    private void StartEdit(Contact c)
    {
        _editingId = c.Id;
        _addingNew = false;
        _fName = c.Name; _fPerson = c.ContactPerson; _fPhone = c.Phone;
        _fAddress = c.Address; _fNotes = c.Notes;
        _fLinks = [.. c.Links]; _newLinkInput = null; _error = null;
    }

    private void CancelForm()
    {
        _addingNew = false;
        _editingId = null;
        _error = null;
    }

    private void AddLink()
    {
        if (!string.IsNullOrWhiteSpace(_newLinkInput))
        {
            _fLinks.Add(_newLinkInput.Trim());
            _newLinkInput = null;
        }
    }

    private async Task SaveAddAsync()
    {
        _busy = true; _error = null;
        CommitPendingLink();
        var id = Guid.NewGuid().ToString("N")[..10];
        var c = BuildContact(id);
        var (ok, error) = await Store.SaveAsync(data => { data.Contacts.Add(c); return true; });
        _busy = false;
        if (ok) { _addingNew = false; _fLinks = []; }
        else _error = error;
    }

    private async Task SaveEditAsync()
    {
        _busy = true; _error = null;
        CommitPendingLink();
        var id = _editingId!;
        var c = BuildContact(id);
        var (ok, error) = await Store.SaveAsync(data =>
        {
            var idx = data.Contacts.FindIndex(x => x.Id == id);
            if (idx < 0) return false;
            data.Contacts[idx] = c;
            return true;
        });
        _busy = false;
        if (ok) _editingId = null;
        else _error = error;
    }

    private async Task DeleteAsync(string id)
    {
        await Store.SaveAsync(data => { data.Contacts.RemoveAll(c => c.Id == id); return true; });
    }

    private void CommitPendingLink()
    {
        if (!string.IsNullOrWhiteSpace(_newLinkInput))
        {
            _fLinks.Add(_newLinkInput.Trim());
            _newLinkInput = null;
        }
    }

    private Contact BuildContact(string id) => new()
    {
        Id = id,
        Name = _fName!.Trim(),
        ContactPerson = string.IsNullOrWhiteSpace(_fPerson) ? null : _fPerson.Trim(),
        Phone = string.IsNullOrWhiteSpace(_fPhone) ? null : _fPhone.Trim(),
        Address = string.IsNullOrWhiteSpace(_fAddress) ? null : _fAddress.Trim(),
        Notes = string.IsNullOrWhiteSpace(_fNotes) ? null : _fNotes.Trim(),
        Links = _fLinks.Where(l => !string.IsNullOrWhiteSpace(l)).Select(l => l.Trim()).ToList()
    };

    private static string MapsUrl(string address) =>
        $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString(address)}";

    private static string DisplayLink(string url)
    {
        try
        {
            var uri = new Uri(url);
            var path = uri.PathAndQuery.TrimEnd('/');
            var host = uri.Host.TrimStart('w').TrimStart('w').TrimStart('w').TrimStart('.');
            return path.Length > 1 ? host + path : host;
        }
        catch
        {
            return url.Length > 42 ? url[..42] + "…" : url;
        }
    }

    // ── Venues ───────────────────────────────────────────────────────────────

    private bool _vAddingNew;
    private string? _vEditingId;
    private bool _vBusy;
    private string? _vError;

    private string? _vfName;
    private string? _vfAddress;
    private string? _vfNotes;
    private HashSet<string> _vfContactIds = [];
    private HashSet<string> _vfPersonIds = [];

    private void StartVenueAdd()
    {
        _vAddingNew = true;
        _vEditingId = null;
        _vfName = null; _vfAddress = null; _vfNotes = null;
        _vfContactIds = []; _vfPersonIds = []; _vError = null;
    }

    private void StartVenueEdit(Venue v)
    {
        _vEditingId = v.Id;
        _vAddingNew = false;
        _vfName = v.Name; _vfAddress = v.Address; _vfNotes = v.Notes;
        _vfContactIds = [.. v.ContactIds]; _vfPersonIds = [.. v.PersonIds]; _vError = null;
    }

    private void CancelVenueForm()
    {
        _vAddingNew = false;
        _vEditingId = null;
        _vError = null;
    }

    private async Task SaveVenueAddAsync()
    {
        _vBusy = true; _vError = null;
        var id = Guid.NewGuid().ToString("N")[..10];
        var v = BuildVenue(id);
        var (ok, error) = await Store.SaveAsync(data => { data.Venues.Add(v); return true; });
        _vBusy = false;
        if (ok) _vAddingNew = false;
        else _vError = error;
    }

    private async Task SaveVenueEditAsync()
    {
        _vBusy = true; _vError = null;
        var id = _vEditingId!;
        var v = BuildVenue(id);
        var (ok, error) = await Store.SaveAsync(data =>
        {
            var idx = data.Venues.FindIndex(x => x.Id == id);
            if (idx < 0) return false;
            data.Venues[idx] = v;
            return true;
        });
        _vBusy = false;
        if (ok) _vEditingId = null;
        else _vError = error;
    }

    private async Task DeleteVenueAsync(string id)
    {
        await Store.SaveAsync(data => { data.Venues.RemoveAll(v => v.Id == id); return true; });
    }

    private Venue BuildVenue(string id) => new()
    {
        Id = id,
        Name = _vfName!.Trim(),
        Address = string.IsNullOrWhiteSpace(_vfAddress) ? null : _vfAddress.Trim(),
        Notes = string.IsNullOrWhiteSpace(_vfNotes) ? null : _vfNotes.Trim(),
        ContactIds = _vfContactIds.ToList(),
        PersonIds = _vfPersonIds.ToList()
    };

    private RenderFragment VenueFields() => __builder =>
    {
        <label class="form-field">
            <span class="form-label">Nom *</span>
            <input class="form-input" type="text" @bind="_vfName"
                   placeholder="ex : Salle des fêtes de Pommiers" autocapitalize="words" />
        </label>
        <label class="form-field">
            <span class="form-label">📍 Adresse <span class="form-hint-inline">(optionnel — lien Maps)</span></span>
            <input class="form-input" type="text" @bind="_vfAddress"
                   placeholder="ex : 12 rue du Bourg, 69480 Pommiers" />
        </label>
        <label class="form-field">
            <span class="form-label">💡 Notes <span class="form-hint-inline">(optionnel)</span></span>
            <textarea class="form-input form-textarea" @bind="_vfNotes" rows="2"
                      placeholder="ex : Parking derrière la mairie, entrer par le portail rouge"></textarea>
        </label>
        @if ((Store.Data?.Contacts.Count ?? 0) > 0)
        {
            <div class="form-field">
                <span class="form-label">📇 Contacts liés</span>
                <div class="contact-checks">
                    @foreach (var c in Store.Data!.Contacts)
                    {
                        var cid = c.Id;
                        <label class="contact-check @(_vfContactIds.Contains(cid) ? "is-checked" : "")">
                            <input type="checkbox"
                                   checked="@_vfContactIds.Contains(cid)"
                                   @onchange="e => { if (e.Value is true) _vfContactIds.Add(cid); else _vfContactIds.Remove(cid); }" />
                            @c.Name
                        </label>
                    }
                </div>
            </div>
        }
        @if ((Store.Data?.People.Count ?? 0) > 0)
        {
            <div class="form-field">
                <span class="form-label">👤 Personnes liées</span>
                <div class="person-checks">
                    @foreach (var p in Store.Data!.People)
                    {
                        var pid = p.Id;
                        <label class="person-check @(_vfPersonIds.Contains(pid) ? "is-checked" : "")"
                               style="--person-color: @p.Color">
                            <input type="checkbox"
                                   checked="@_vfPersonIds.Contains(pid)"
                                   @onchange="e => { if (e.Value is true) _vfPersonIds.Add(pid); else _vfPersonIds.Remove(pid); }" />
                            @p.Name
                        </label>
                    }
                </div>
            </div>
        }
    };

    private RenderFragment ContactFields() => __builder =>
    {
        <label class="form-field">
            <span class="form-label">Nom *</span>
            <input class="form-input" type="text" @bind="_fName"
                   placeholder="ex : Fleuriste Dupont" autocapitalize="words" />
        </label>
        <label class="form-field">
            <span class="form-label">👤 Interlocuteur</span>
            <input class="form-input" type="text" @bind="_fPerson"
                   placeholder="ex : Marie" autocapitalize="words" />
        </label>
        <label class="form-field">
            <span class="form-label">📞 Téléphone</span>
            <input class="form-input" type="tel" @bind="_fPhone"
                   placeholder="+33 4 74 12 34 56" />
        </label>
        <label class="form-field">
            <span class="form-label">📍 Adresse</span>
            <input class="form-input" type="text" @bind="_fAddress"
                   placeholder="ex : 12 rue des Lilas, 69400 Anse" />
        </label>
        <label class="form-field">
            <span class="form-label">💡 Notes</span>
            <textarea class="form-input form-textarea" @bind="_fNotes" rows="3"
                      placeholder="ex : Livraison avant 10h, sonnez 2 fois"></textarea>
        </label>
        @if (_fLinks.Count > 0)
        {
            <div class="form-field">
                <span class="form-label">🔗 Liens</span>
                @for (int i = 0; i < _fLinks.Count; i++)
                {
                    var idx = i;
                    <div class="link-row">
                        <span class="link-row-url">@_fLinks[idx]</span>
                        <button type="button" class="btn-card-icon" @onclick="() => _fLinks.RemoveAt(idx)">✕</button>
                    </div>
                }
            </div>
        }
        <div class="add-form-row link-add-row">
            <input class="form-input" type="url" @bind="_newLinkInput" @bind:event="oninput"
                   placeholder="https://…" />
            <button type="button" class="action-btn btn-clear link-add-btn"
                    @onclick="AddLink"
                    disabled="@string.IsNullOrWhiteSpace(_newLinkInput)">
                + Lien
            </button>
        </div>
    };
}
