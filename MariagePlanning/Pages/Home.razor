@page "/"
@implements IDisposable
@inject WeddingStore Store
@inject SettingsService Config
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Mariage Planning</PageTitle>

@* Bloc QR — masqué à l'écran, visible à l'impression *@
<div class="print-qr-block">
    <div id="print-qr"></div>
    <p class="print-qr-label">Scanner pour accéder au planning sur votre téléphone</p>
    @if (Config.IsConfigured)
    {
        <p class="print-qr-url">@($"{Nav.BaseUri}rejoindre#{Config.GistId}")</p>
    }
</div>

@if (Store.Data is null)
{
    @if (Store.LoadError is not null)
    {
        <div class="load-error">
            <p>⚠️ Impossible de charger le planning.</p>
            <p class="error-detail">@Store.LoadError</p>
            <button class="action-btn btn-refresh" @onclick="ReloadAsync">🔄 Réessayer</button>
        </div>
    }
    else
    {
        <div class="loading-message">Chargement du planning…</div>
    }
}
else
{
    @* ── Planning complet pour impression (masqué à l'écran) ────────────── *@
    <div class="print-planning">
        <h1 class="print-planning-title">@Store.Data.Wedding.Name</h1>
        <p class="print-planning-date">Planning complet — imprimé le @DateTime.Now.ToString("d MMMM yyyy")</p>
        @foreach (var day in Store.OrderedDays)
        {
            <div class="print-day-block">
                <h2 class="print-day-heading">
                    @FrenchDate.Long(day.Date) — @day.Label
                    @if (Store.IsWeddingDay(day)) { <span> ✨ Jour J</span> }
                </h2>
                @if (!day.Activities.Any())
                {
                    <p class="print-empty">Aucune tâche prévue.</p>
                }
                else
                {
                    @foreach (var task in day.Activities.OrderBy(t => t.Time ?? "99:99"))
                    {
                        var people = task.AssignedTo.Count == 0
                            ? "Tout le monde"
                            : string.Join(", ", Store.AssignedPeople(task).Select(p => p.Name));
                        <div class="print-task-row">
                            <span class="print-task-time">@(task.Time ?? "—")</span>
                            <span class="print-task-title">@task.Title</span>
                            <span class="print-task-who">@people</span>
                            @if (!string.IsNullOrWhiteSpace(task.Location))
                            {
                                <span class="print-task-loc">📍 @task.Location</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(task.Notes))
                        {
                            <div class="print-task-notes">💡 @task.Notes</div>
                        }
                    }
                }
            </div>
        }
    </div>

    <div class="tile-grid">

        @* ── Compte à rebours ────────────────────────────────────────── *@
        <div class="tile tile-full tile-hero">
            <div class="tile-hero-top">
                <div class="tile-hero-name">@Store.Data.Wedding.Name</div>
                @switch (Store.Source)
                {
                    case DataSource.Gist:
                        <span class="tile-hero-badge tile-badge-ok">✓ sync</span>
                        break;
                    case DataSource.Cache:
                        <span class="tile-hero-badge tile-badge-warn">📵 hors ligne</span>
                        break;
                    case DataSource.Demo:
                        <span class="tile-hero-badge tile-badge-demo">démo</span>
                        break;
                }
            </div>
            <div class="tile-countdown">@(_countdownDays?.ToString() ?? "🥂")</div>
            <div class="tile-countdown-label">@_countdownLabel</div>
        </div>

        @* ── Prochaine tâche — contenu affiché directement ──────────── *@
        @if (_nextTask is not null && _nextDay is not null)
        {
            <a class="tile tile-full tile-next" href="jour/@_nextDay.Date.ToString("yyyy-MM-dd")">
                <div class="tile-eyebrow">
                    @(_currentPerson is not null ? "⏭ MA PROCHAINE TÂCHE" : "⏭ PROCHAINE TÂCHE")
                </div>
                <div class="tile-next-title">@_nextTask.Title</div>
                <div class="tile-next-meta">
                    @if (_nextTask.Time is not null) { <span>⏰ @_nextTask.Time</span> }
                    <span>@FrenchDate.Long(_nextDay.Date)</span>
                    @if (!string.IsNullOrWhiteSpace(_nextTask.Location)) { <span>📍 @_nextTask.Location</span> }
                </div>
            </a>
        }
        else if (Store.Data.People.Count > 0 && _currentPerson is null)
        {
            <a class="tile tile-full tile-next-hint" href="moi">
                <div class="tile-eyebrow">💡 ASTUCE</div>
                <div class="tile-next-title">Sélectionne ton profil</div>
                <div class="tile-next-meta"><span>pour voir ta prochaine tâche →</span></div>
            </a>
        }

        @* ── Une tuile par jour — avec compteur de tâches ───────────── *@
        @foreach (var day in Store.OrderedDays)
        {
            var total     = day.Activities.Count;
            var isWedding = Store.IsWeddingDay(day);
            var isToday   = day.Date == DateOnly.FromDateTime(DateTime.Now);
            var myCount   = _currentPerson is null ? 0
                            : day.Activities.Count(t => t.AssignedTo.Contains(_currentPerson.Id));
            var firstTask = day.Activities
                .Where(t => t.Time is not null)
                .OrderBy(t => t.Time)
                .FirstOrDefault();
            var d = day;

            <div class="tile tile-day-wrap @(isWedding ? "tile-wedding" : isToday ? "tile-today" : "tile-day")">
                <a class="tile-day-inner" href="jour/@day.Date.ToString("yyyy-MM-dd")">
                    <div class="tile-day-num">@day.Date.Day</div>
                    <div class="tile-sub">@day.Label</div>
                    <div class="tile-day-footer">
                        <span class="tile-tag">@_months[day.Date.Month - 1]</span>
                        @if (_currentPerson is not null && myCount > 0)
                        {
                            <span class="tile-mine-badge">@myCount moi</span>
                        }
                        else if (_currentPerson is null && total > 0)
                        {
                            <span class="tile-tag">@total tâche@(total > 1 ? "s" : "")</span>
                        }
                    </div>
                    @if (firstTask is not null)
                    {
                        <div class="tile-day-first">⏰ @firstTask.Time</div>
                    }
                </a>
                @if (Store.CanEdit)
                {
                    <a class="tile-quick-add no-print"
                       href="jour/@d.Date.ToString("yyyy-MM-dd")?add=1"
                       title="Ajouter une tâche">➕</a>
                }
            </div>
        }

        @* ── Mon profil — lien vers planning perso ───────────────────── *@
        <a class="tile @(_currentPerson is not null ? "tile-person" : "tile-muted")"
           href="moi"
           style="@(_currentPerson is not null ? $"--person-color:{_currentPerson.Color}" : "")">
            @if (_currentPerson is not null)
            {
                <div class="tile-avatar">@_currentPerson.Name[0]</div>
                <div class="tile-sub">@_currentPerson.Name</div>
                @if (_myTotal > 0)
                {
                    <div class="tile-tag">@_myTotal tâche@(_myTotal > 1 ? "s" : "")</div>
                }
            }
            else
            {
                <div class="tile-icon-lg">👤</div>
                <div class="tile-tag">MON PLANNING</div>
            }
        </a>

        @* ── Contacts ────────────────────────────────────────────────── *@
        <a class="tile tile-muted" href="contacts">
            <div class="tile-big-num">@Store.Data.Contacts.Count</div>
            <div class="tile-tag">CONTACTS</div>
        </a>

        @* ── Todos ───────────────────────────────────────────────────── *@
        @{
            var today2    = DateOnly.FromDateTime(DateTime.Now);
            var todoTotal = Store.Data.Todos.Count(t => !t.IsDone);
            var todoLate  = Store.Data.Todos.Count(t => !t.IsDone && t.DueDate.HasValue && t.DueDate < today2);
        }
        <a class="tile @(todoLate > 0 ? "tile-todo-late" : "tile-muted")" href="todos">
            <div class="tile-big-num">@todoTotal</div>
            <div class="tile-tag">À FAIRE</div>
            @if (todoLate > 0)
            {
                <div class="tile-sub" style="font-size:10px;opacity:.85">⚠️ @todoLate en retard</div>
            }
        </a>

        @* ── Actions ─────────────────────────────────────────────────── *@
        <button class="tile tile-action no-print" @onclick="ReloadAsync" disabled="@_reloading">
            <div class="tile-icon-lg">@(_reloading ? "⏳" : "🔄")</div>
            <div class="tile-tag">ACTUALISER</div>
        </button>
        <button class="tile tile-action no-print" @onclick="PrintAsync">
            <div class="tile-icon-lg">🖨️</div>
            <div class="tile-tag">PDF</div>
        </button>

        @* ── Ajouter un jour ─────────────────────────────────────────── *@
        @if (Store.CanEdit)
        {
            @if (_addingDay)
            {
                <div class="tile-full add-form">
                    <label class="form-field">
                        <span class="form-label">Date *</span>
                        <input class="form-input" type="date" @bind="_newDayDate" />
                    </label>
                    <label class="form-field">
                        <span class="form-label">Libellé du jour</span>
                        <input class="form-input" type="text" @bind="_newDayLabel"
                               placeholder="ex : J-2 — Préparation" autocapitalize="sentences" />
                    </label>
                    @if (_dayError is not null) { <div class="sync-status sync-warn">⚠️ @_dayError</div> }
                    <div class="add-form-actions">
                        <button class="action-btn btn-clear" @onclick="() => _addingDay = false" disabled="@_dayBusy">Annuler</button>
                        <button class="action-btn btn-refresh" @onclick="AddDayAsync"
                                disabled="@(_dayBusy || _newDayDate is null)">
                            @(_dayBusy ? "⏳…" : "📅 Ajouter ce jour")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <button class="tile tile-add-day tile-full no-print" @onclick="() => _addingDay = true">
                    <div class="tile-icon-lg">📅</div>
                    <div class="tile-tag">AJOUTER UN JOUR</div>
                </button>
            }
        }

    </div>
}

@code {
    private bool _reloading;
    private bool _addingDay;
    private DateTime? _newDayDate;
    private string? _newDayLabel;
    private bool _dayBusy;
    private string? _dayError;

    private Person?   _currentPerson;
    private int?      _countdownDays;
    private string    _countdownLabel = "jours";
    private WeddingDay? _nextDay;
    private TaskItem?   _nextTask;
    private int         _myTotal;

    private static readonly string[] _months =
        ["Jan", "Fév", "Mar", "Avr", "Mai", "Jun", "Jul", "Août", "Sep", "Oct", "Nov", "Déc"];

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnStoreChanged;
        await Config.EnsureLoadedAsync();
        await Store.EnsureLoadedAsync();
        Recompute();
    }

    public void Dispose() => Store.Changed -= OnStoreChanged;

    private void OnStoreChanged() { Recompute(); InvokeAsync(StateHasChanged); }

    private void Recompute()
    {
        if (Store.Data is null) return;

        // Countdown
        var today = DateOnly.FromDateTime(DateTime.Now);
        if (Store.WeddingDate is { } wd)
        {
            if (today < wd)      { _countdownDays = wd.DayNumber - today.DayNumber; _countdownLabel = "jours avant le mariage 💍"; }
            else if (today == wd){ _countdownDays = null; _countdownLabel = "C'est le grand jour ! ✨"; }
            else                 { _countdownDays = null; _countdownLabel = "Mariés ! 🥂"; }
        }

        // Personne + total de mes tâches
        _currentPerson = Config.CurrentPerson is { } id ? Store.PersonById(id) : null;
        _myTotal = _currentPerson is null ? 0
            : Store.Data.Days.Sum(d => d.Activities.Count(t => t.AssignedTo.Contains(_currentPerson.Id)));

        // Prochaine tâche
        _nextDay = null; _nextTask = null;
        var personId = Config.CurrentPerson;
        foreach (var day in Store.OrderedDays.Where(d => d.Date >= today))
        {
            var task = day.Activities
                .Where(t => !t.IsDone && (personId is null || WeddingStore.ConcernsPerson(t, personId)))
                .OrderBy(t => t.Time ?? "99:99")
                .FirstOrDefault();
            if (task is not null) { _nextDay = day; _nextTask = task; break; }
        }
    }

    private async Task ReloadAsync()
    {
        _reloading = true;
        await Store.ReloadAsync();
        Recompute();
        _reloading = false;
    }

    private async Task PrintAsync()
    {
        var shareUrl = Config.IsConfigured ? $"{Nav.BaseUri}rejoindre#{Config.GistId}" : null;
        await JS.InvokeVoidAsync("mariage.printPlan", shareUrl);
    }

    private async Task AddDayAsync()
    {
        if (_newDayDate is null) return;
        _dayBusy = true; _dayError = null;
        var date  = DateOnly.FromDateTime(_newDayDate.Value);
        var label = string.IsNullOrWhiteSpace(_newDayLabel) ? FrenchDate.Long(date) : _newDayLabel.Trim();

        var (ok, error) = await Store.SaveAsync(data =>
        {
            if (data.Days.Any(d => d.Date == date)) return false;
            data.Days.Add(new WeddingDay { Date = date, Label = label });
            return true;
        });

        _dayBusy = false;
        if (ok) { _addingDay = false; _newDayDate = null; _newDayLabel = null; }
        else _dayError = error ?? "Ce jour existe déjà.";
    }
}
