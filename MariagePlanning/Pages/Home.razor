@page "/"
@implements IDisposable
@inject WeddingStore Store
@inject SettingsService Config
@inject IJSRuntime JS

<PageTitle>Mariage Planning</PageTitle>

@if (Store.Data is null)
{
    @if (Store.LoadError is not null)
    {
        <div class="load-error">
            <p>⚠️ Impossible de charger le planning.</p>
            <p class="error-detail">@Store.LoadError</p>
            <button class="action-btn btn-refresh" @onclick="ReloadAsync">🔄 Réessayer</button>
        </div>
    }
    else
    {
        <div class="loading-message">Chargement du planning…</div>
    }
}
else
{
    <header class="page-header">
        <h1>@Store.Data.Wedding.Name</h1>
        @if (CountdownText is not null)
        {
            <div class="wedding-countdown">@CountdownText</div>
        }
        @switch (Store.Source)
        {
            case DataSource.Gist:
                <div class="sync-status sync-ok">✅ Synchronisé @SyncTime</div>
                break;
            case DataSource.Cache:
                <div class="sync-status sync-offline">📵 Hors ligne — synchronisé @SyncTime</div>
                break;
            case DataSource.Demo:
                <div class="sync-status sync-demo">🧪 Données de démo — <a href="parametres">configurer</a></div>
                break;
        }
        <div class="header-actions no-print">
            <button class="action-btn btn-refresh" @onclick="ReloadAsync" disabled="@_reloading">
                @(_reloading ? "⏳…" : "🔄 Actualiser")
            </button>
            <button class="action-btn btn-print" @onclick="PrintAsync" title="Exporter en PDF">🖨️ PDF</button>
        </div>
    </header>

    @* Prochaine tâche *@
    @if (_nextTask is not null && _nextDay is not null)
    {
        <a class="next-task-card" href="jour/@_nextDay.Date.ToString("yyyy-MM-dd")">
            <div class="next-task-eyebrow">⏭️ Prochaine tâche</div>
            <div class="next-task-title">@_nextTask.Title</div>
            <div class="next-task-meta">
                @if (_nextTask.Time is not null)
                {
                    <span>⏰ @_nextTask.Time</span>
                }
                <span>📅 @FrenchDate.Long(_nextDay.Date) — @_nextDay.Label</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(_nextTask.Location))
            {
                <div class="next-task-location">📍 @_nextTask.Location</div>
            }
            @if (_nextTask.ContactIds.Count > 0)
            {
                <div class="next-task-contacts">
                    @foreach (var cid in _nextTask.ContactIds)
                    {
                        var contact = Store.Data!.Contacts.FirstOrDefault(c => c.Id == cid);
                        if (contact is null) continue;
                        <span class="task-contact-chip">
                            <span class="chip-name">@contact.Name</span>
                        </span>
                    }
                </div>
            }
        </a>
    }
    else if (Store.Data.People.Count > 0 && Config.CurrentPerson is null)
    {
        <div class="next-task-hint">
            👤 Sélectionne ton profil dans <a href="moi">l'onglet Moi</a> pour voir ta prochaine tâche.
        </div>
    }

    @* Boutons des jours *@
    <div class="home-days">
        @foreach (var day in Store.OrderedDays)
        {
            var done = day.Activities.Count(t => t.IsDone);
            var total = day.Activities.Count;
            var isWedding = Store.IsWeddingDay(day);
            var isToday = day.Date == DateOnly.FromDateTime(DateTime.Now);
            <a class="day-nav-btn @(isWedding ? "day-nav-wedding" : "") @(isToday ? "day-nav-today" : "")"
               href="jour/@day.Date.ToString("yyyy-MM-dd")">
                <div class="day-nav-info">
                    <span class="day-nav-label">@day.Label</span>
                    <span class="day-nav-date">@FrenchDate.Long(day.Date)</span>
                </div>
                <div class="day-nav-right">
                    @if (isWedding) { <span class="badge badge-wedding">✨</span> }
                    @if (isToday) { <span class="badge badge-today">Auj.</span> }
                    @if (total > 0)
                    {
                        <span class="badge @(done == total ? "badge-done" : "badge-todo")">@done/@total</span>
                    }
                    <span class="day-nav-arrow">›</span>
                </div>
            </a>
        }

        @if (Store.CanEdit)
        {
            @if (_addingDay)
            {
                <div class="add-form" style="margin-top: 4px">
                    <label class="form-field">
                        <span class="form-label">Date *</span>
                        <input class="form-input" type="date" @bind="_newDayDate" />
                    </label>
                    <label class="form-field">
                        <span class="form-label">Libellé du jour</span>
                        <input class="form-input" type="text" @bind="_newDayLabel"
                               placeholder="ex : J-2 — Préparation" autocapitalize="sentences" />
                    </label>
                    @if (_dayError is not null)
                    {
                        <div class="sync-status sync-warn">⚠️ @_dayError</div>
                    }
                    <div class="add-form-actions">
                        <button class="action-btn btn-clear" @onclick="() => _addingDay = false" disabled="@_dayBusy">Annuler</button>
                        <button class="action-btn btn-refresh" @onclick="AddDayAsync"
                                disabled="@(_dayBusy || _newDayDate is null)">
                            @(_dayBusy ? "⏳…" : "📅 Ajouter ce jour")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <button class="action-btn btn-add home-add-day" @onclick="() => _addingDay = true">
                    📅 Ajouter un jour
                </button>
            }
        }
    </div>
}

@code {
    private bool _reloading;
    private WeddingDay? _nextDay;
    private TaskItem? _nextTask;

    private bool _addingDay;
    private DateTime? _newDayDate;
    private string? _newDayLabel;
    private bool _dayBusy;
    private string? _dayError;

    private string SyncTime =>
        Store.LastSync is { } d ? $"le {d:dd/MM} à {d:HH\\hmm}" : "";

    private string? CountdownText
    {
        get
        {
            if (Store.WeddingDate is not { } weddingDay) return null;
            var today = DateOnly.FromDateTime(DateTime.Now);
            if (today < weddingDay)
            {
                var days = weddingDay.DayNumber - today.DayNumber;
                return days == 1 ? "C'est demain ! 💍" : $"J-{days} avant le mariage 💍";
            }
            if (today == weddingDay) return "C'est le grand jour ! ✨💍";
            return "Mariés ! 🥂";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnStoreChanged;
        await Config.EnsureLoadedAsync();
        await Store.EnsureLoadedAsync();
        ComputeNextTask();
    }

    public void Dispose() => Store.Changed -= OnStoreChanged;

    private void OnStoreChanged()
    {
        ComputeNextTask();
        InvokeAsync(StateHasChanged);
    }

    private void ComputeNextTask()
    {
        _nextDay = null;
        _nextTask = null;
        if (Store.Data is null) return;

        var personId = Config.CurrentPerson;
        var today = DateOnly.FromDateTime(DateTime.Now);

        foreach (var day in Store.OrderedDays.Where(d => d.Date >= today))
        {
            var task = day.Activities
                .Where(t => !t.IsDone && (personId is null || WeddingStore.ConcernsPerson(t, personId)))
                .OrderBy(t => t.Time ?? "99:99")
                .FirstOrDefault();
            if (task is not null) { _nextDay = day; _nextTask = task; break; }
        }
    }

    private async Task ReloadAsync()
    {
        _reloading = true;
        await Store.ReloadAsync();
        ComputeNextTask();
        _reloading = false;
    }

    private async Task PrintAsync() =>
        await JS.InvokeVoidAsync("mariage.printPlan");

    private async Task AddDayAsync()
    {
        if (_newDayDate is null) return;
        _dayBusy = true;
        _dayError = null;
        var date = DateOnly.FromDateTime(_newDayDate.Value);
        var label = string.IsNullOrWhiteSpace(_newDayLabel)
            ? FrenchDate.Long(date)
            : _newDayLabel.Trim();

        var (ok, error) = await Store.SaveAsync(data =>
        {
            if (data.Days.Any(d => d.Date == date)) return false;
            data.Days.Add(new WeddingDay { Date = date, Label = label });
            return true;
        });

        _dayBusy = false;
        if (ok) { _addingDay = false; _newDayDate = null; _newDayLabel = null; }
        else _dayError = error ?? "Ce jour existe déjà.";
    }
}
