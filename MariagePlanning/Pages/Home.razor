@page "/"
@implements IDisposable
@inject WeddingStore Store
@inject SettingsService Config
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Mariage Planning</PageTitle>

@* Bloc QR code — masqué à l'écran, affiché uniquement à l'impression *@
<div class="print-qr-block">
    <div id="print-qr"></div>
    <p class="print-qr-label">Scanner pour accéder au planning sur votre téléphone</p>
    @if (Config.IsConfigured)
    {
        <p class="print-qr-url">@($"{Nav.BaseUri}rejoindre#{Config.GistId}")</p>
    }
</div>

@if (Store.Data is null)
{
    @if (Store.LoadError is not null)
    {
        <div class="load-error">
            <p>⚠️ Impossible de charger le planning.</p>
            <p class="error-detail">@Store.LoadError</p>
            <button class="action-btn btn-refresh" @onclick="ReloadAsync">🔄 Réessayer</button>
        </div>
    }
    else
    {
        <div class="loading-message">Chargement du planning…</div>
    }
}
else
{
    @* ── En-tête compact ─────────────────────────────────────────────── *@
    <header class="agenda-header">
        <div class="agenda-title-row">
            <h1 class="agenda-title">@Store.Data.Wedding.Name</h1>
            @if (_countdownDays is not null)
            {
                <span class="agenda-countdown">J-@_countdownDays</span>
            }
            else if (Store.WeddingDate is not null)
            {
                <span class="agenda-countdown">💍</span>
            }
        </div>

        <div class="agenda-actions no-print">
            <a class="agenda-btn @(_currentPerson is not null ? "agenda-btn-person" : "")"
               href="moi"
               style="@(_currentPerson is not null ? $"--person-color:{_currentPerson.Color}" : "")">
                @if (_currentPerson is not null) { <span>👤 @_currentPerson.Name</span> }
                else { <span>👤 Choisir mon profil</span> }
            </a>
            @if (_currentPerson is not null)
            {
                <button class="agenda-btn @(_onlyMe ? "agenda-btn-active" : "")"
                        @onclick="() => _onlyMe = !_onlyMe">
                    @(_onlyMe ? "✅ Moi seulement" : "Moi seulement")
                </button>
            }
            <button class="agenda-btn" @onclick="ReloadAsync" disabled="@_reloading">
                @(_reloading ? "⏳" : "🔄")
            </button>
            <button class="agenda-btn" @onclick="PrintAsync">🖨️</button>
        </div>

        <div class="agenda-status-row">
            @switch (Store.Source)
            {
                case DataSource.Gist:
                    <span class="agenda-status">✓ synchronisé @SyncTime</span>
                    break;
                case DataSource.Cache:
                    <span class="agenda-status agenda-status-warn">📵 hors ligne — @SyncTime</span>
                    break;
                case DataSource.Demo:
                    <span class="agenda-status">🧪 données de démo — <a href="parametres" style="color:inherit">configurer</a></span>
                    break;
            }
        </div>
    </header>

    @* ── Planning complet ─────────────────────────────────────────────── *@
    @foreach (var day in Store.OrderedDays)
    {
        var today     = DateOnly.FromDateTime(DateTime.Now);
        var personId  = Config.CurrentPerson;

        if (_onlyMe && personId is not null
            && !day.Activities.Any(t => t.AssignedTo.Contains(personId)))
            continue;

        <DaySection Day="day"
                    PersonId="personId"
                    StrictFilter="@_onlyMe"
                    InitiallyOpen="@(day.Date >= today)" />
    }

    @* ── Ajouter un jour ─────────────────────────────────────────────── *@
    @if (Store.CanEdit)
    {
        @if (_addingDay)
        {
            <div class="add-form" style="margin-top:8px">
                <label class="form-field">
                    <span class="form-label">Date *</span>
                    <input class="form-input" type="date" @bind="_newDayDate" />
                </label>
                <label class="form-field">
                    <span class="form-label">Libellé du jour</span>
                    <input class="form-input" type="text" @bind="_newDayLabel"
                           placeholder="ex : J-2 — Préparation" autocapitalize="sentences" />
                </label>
                @if (_dayError is not null)
                {
                    <div class="sync-status sync-warn">⚠️ @_dayError</div>
                }
                <div class="add-form-actions">
                    <button class="action-btn btn-clear" @onclick="() => _addingDay = false" disabled="@_dayBusy">Annuler</button>
                    <button class="action-btn btn-refresh" @onclick="AddDayAsync"
                            disabled="@(_dayBusy || _newDayDate is null)">
                        @(_dayBusy ? "⏳…" : "📅 Ajouter ce jour")
                    </button>
                </div>
            </div>
        }
        else
        {
            <button class="action-btn btn-add home-add-day no-print" @onclick="() => _addingDay = true">
                📅 Ajouter un jour
            </button>
        }
    }
}

@code {
    private bool _reloading;
    private bool _addingDay;
    private DateTime? _newDayDate;
    private string? _newDayLabel;
    private bool _dayBusy;
    private string? _dayError;

    private Person? _currentPerson;
    private int? _countdownDays;
    private bool _onlyMe;

    private string SyncTime =>
        Store.LastSync is { } d ? $"le {d:dd/MM} à {d:HH\\hmm}" : "";

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnStoreChanged;
        await Config.EnsureLoadedAsync();
        await Store.EnsureLoadedAsync();
        Recompute();
    }

    public void Dispose() => Store.Changed -= OnStoreChanged;

    private void OnStoreChanged()
    {
        Recompute();
        InvokeAsync(StateHasChanged);
    }

    private void Recompute()
    {
        _currentPerson = Config.CurrentPerson is { } id ? Store.PersonById(id) : null;

        if (Store.WeddingDate is { } wd)
        {
            var today = DateOnly.FromDateTime(DateTime.Now);
            _countdownDays = today < wd ? wd.DayNumber - today.DayNumber : (int?)null;
        }
        else
        {
            _countdownDays = null;
        }
    }

    private async Task ReloadAsync()
    {
        _reloading = true;
        await Store.ReloadAsync();
        Recompute();
        _reloading = false;
    }

    private async Task PrintAsync()
    {
        var shareUrl = Config.IsConfigured
            ? $"{Nav.BaseUri}rejoindre#{Config.GistId}"
            : null;
        await JS.InvokeVoidAsync("mariage.printPlan", shareUrl);
    }

    private async Task AddDayAsync()
    {
        if (_newDayDate is null) return;
        _dayBusy  = true;
        _dayError = null;
        var date  = DateOnly.FromDateTime(_newDayDate.Value);
        var label = string.IsNullOrWhiteSpace(_newDayLabel)
            ? FrenchDate.Long(date)
            : _newDayLabel.Trim();

        var (ok, error) = await Store.SaveAsync(data =>
        {
            if (data.Days.Any(d => d.Date == date)) return false;
            data.Days.Add(new WeddingDay { Date = date, Label = label });
            return true;
        });

        _dayBusy = false;
        if (ok) { _addingDay = false; _newDayDate = null; _newDayLabel = null; }
        else _dayError = error ?? "Ce jour existe déjà.";
    }
}
