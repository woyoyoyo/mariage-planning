@inject WeddingStore Store
@inject IJSRuntime JS

<details class="day-card @(IsWeddingDay ? "day-wedding" : "")" id="day-@Day.Date.ToString("yyyy-MM-dd")">
    <summary class="day-summary">
        <div class="day-summary-main">
            <div class="day-summary-text">
                <span class="day-date">@FrenchDate.Long(Day.Date)</span>
                <span class="day-title">@Day.Label</span>
            </div>
        </div>
        <div class="day-badges">
            @if (IsWeddingDay)
            {
                <span class="badge badge-wedding">✨ Jour J</span>
            }
            @if (IsToday)
            {
                <span class="badge badge-today">Aujourd'hui</span>
            }
            @if (TodoCount > 0)
            {
                <span class="badge badge-todo">@DoneCount/@(TodoCount + DoneCount)</span>
            }
            <button class="btn-share-day no-print"
                    @onclick="ShareAsync"
                    @onclick:stopPropagation="true"
                    title="Partager ce jour">📤</button>
        </div>
    </summary>

    <div class="day-body">
        @if (UntimedTasks.Any())
        {
            <div class="timeline-allday">
                <span class="timeline-allday-label">📌 Sans horaire</span>
                @foreach (var task in UntimedTasks)
                {
                    <TaskCard Task="task" Date="Day.Date" />
                }
            </div>
        }

        @if (TimedGroups.Any())
        {
            <div class="timeline">
                @foreach (var group in TimedGroups)
                {
                    <div class="timeline-slot">
                        <div class="timeline-left">
                            <span class="timeline-time-label">@group.Key</span>
                            <span class="timeline-dot"></span>
                        </div>
                        <div class="timeline-right">
                            @foreach (var task in group)
                            {
                                <TaskCard Task="task" Date="Day.Date" HideTime="true" />
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @if (!FilteredTasks.Any())
        {
            <div class="empty-day">Rien de prévu ce jour-là pour l'instant.</div>
        }

        @if (PersonId is null)
        {
            <AddTaskForm Date="Day.Date" />
        }
    </div>
</details>

@code {
    [Parameter, EditorRequired]
    public WeddingDay Day { get; set; } = default!;

    /// <summary>Si renseigné, n'affiche que les tâches concernant cette personne (vue "Mon planning").</summary>
    [Parameter]
    public string? PersonId { get; set; }

    private bool IsToday => Day.Date == DateOnly.FromDateTime(DateTime.Now);
    private bool IsWeddingDay => Store.IsWeddingDay(Day);

    private IEnumerable<TaskItem> FilteredTasks =>
        PersonId is null
            ? Day.Activities
            : Day.Activities.Where(t => WeddingStore.ConcernsPerson(t, PersonId));

    private IEnumerable<TaskItem> UntimedTasks =>
        FilteredTasks.Where(t => t.Time is null);

    private IEnumerable<IGrouping<string, TaskItem>> TimedGroups =>
        FilteredTasks
            .Where(t => t.Time is not null)
            .OrderBy(t => t.Time, StringComparer.Ordinal)
            .GroupBy(t => t.Time!);

    private int TodoCount => FilteredTasks.Count(t => !t.IsDone);
    private int DoneCount => FilteredTasks.Count(t => t.IsDone);

    private async Task ShareAsync()
    {
        var text = BuildShareText();
        try
        {
            await JS.InvokeVoidAsync("mariage.shareText", text);
        }
        catch { /* share non supporté ou annulé */ }
    }

    private string BuildShareText()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"📅 {FrenchDate.Long(Day.Date)} — {Day.Label}");
        sb.AppendLine();

        var sorted = FilteredTasks
            .OrderBy(t => t.Time is not null)
            .ThenBy(t => t.Time, StringComparer.Ordinal);
        foreach (var t in sorted)
        {
            var check = t.IsDone ? "✅" : "⬜";
            var time = t.Time is not null ? $"{t.Time}  " : "";
            sb.AppendLine($"{check} {time}{t.Title}");

            var people = t.AssignedTo.Count == 0
                ? "Tout le monde"
                : string.Join(", ", Store.AssignedPeople(t).Select(p => p.Name));
            sb.AppendLine($"  👤 {people}");
            if (!string.IsNullOrWhiteSpace(t.Notes))
                sb.AppendLine($"  💡 {t.Notes}");
        }

        sb.AppendLine();
        sb.Append("— Mariage Planning 💍");
        return sb.ToString().Trim();
    }
}
